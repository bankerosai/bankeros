{
  "dashboard": {
    "title": "BankerOS — Operational Overview",
    "tags": ["bankeros", "banking", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Payment Volume by Network (5m rate)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [{
          "expr": "sum(rate(bankeros_payments_processed_total[5m])) by (network)",
          "legendFormat": "{{ network }}"
        }]
      },
      {
        "id": 2,
        "title": "Fraud Blocks per Hour",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [{
          "expr": "sum(rate(bankeros_fraud_blocks_total[1h])) * 3600"
        }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "p95 HTTP Latency by Service",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [{
          "expr": "histogram_quantile(0.95, sum(rate(bankeros_http_request_duration_seconds_bucket[5m])) by (service, le))",
          "legendFormat": "{{ service }}"
        }],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 4,
        "title": "Active Loans by Status",
        "type": "piechart",
        "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
        "targets": [{
          "expr": "sum(bankeros_loans_active) by (status)",
          "legendFormat": "{{ status }}"
        }]
      },
      {
        "id": 5,
        "title": "Journal Entries Posted (5m rate)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 18, "h": 6 },
        "targets": [{
          "expr": "sum(rate(bankeros_journal_entries_total[5m])) by (reference_type)",
          "legendFormat": "{{ reference_type }}"
        }]
      }
    ]
  }
}
