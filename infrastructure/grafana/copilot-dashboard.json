{
  "annotations": { "list": [] },
  "description": "Banker Copilot — token consumption, cost, latency, tool-call quality. Source: banker_copilot_* metrics from apps/banker-copilot-service.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "tags": ["bankeros", "copilot", "llm", "finops"],
  "timezone": "browser",
  "title": "Banker Copilot — FinOps & Quality",
  "uid": "bankeros-copilot",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "role",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(banker_copilot_turns_total, role)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(banker_copilot_turns_total{role=~\"$role\"}, model)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Cost & Volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total cost (USD, period)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(banker_copilot_cost_usd_total{role=~\"$role\", model=~\"$model\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Turns (period)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "calcs": ["last"] } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(increase(banker_copilot_turns_total{role=~\"$role\", model=~\"$model\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sessions started (period)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "calcs": ["last"] } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(increase(banker_copilot_sessions_started_total{role=~\"$role\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Artefacts created",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "calcs": ["last"] } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(increase(banker_copilot_artefacts_created_total{role=~\"$role\"}[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Cost by role (USD/min)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "expr": "sum by (role) (rate(banker_copilot_cost_usd_total{role=~\"$role\", model=~\"$model\"}[5m])) * 60",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Cost by model (USD/min)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "expr": "sum by (model) (rate(banker_copilot_cost_usd_total{role=~\"$role\", model=~\"$model\"}[5m])) * 60",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Turn latency P50 / P95 / P99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(banker_copilot_turn_latency_ms_bucket{role=~\"$role\", model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(banker_copilot_turn_latency_ms_bucket{role=~\"$role\", model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(banker_copilot_turn_latency_ms_bucket{role=~\"$role\", model=~\"$model\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Tokens / sec by direction",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (direction) (rate(banker_copilot_tokens_total{role=~\"$role\", model=~\"$model\"}[5m]))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Quality & Safety",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Tool call rate by outcome",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(banker_copilot_tool_calls_total{role=~\"$role\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "bargauge",
      "title": "Top tools (calls / min)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "options": { "displayMode": "lcd", "orientation": "horizontal", "showUnfilled": true },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "topk(8, sum by (tool) (rate(banker_copilot_tool_calls_total{role=~\"$role\"}[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Rate limit hits per minute",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(banker_copilot_rate_limit_hits_total{role=~\"$role\"}[5m])) * 60",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Skill mix (artefacts / hour)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum by (skill) (rate(banker_copilot_artefacts_created_total{role=~\"$role\"}[15m])) * 3600",
          "legendFormat": "{{skill}}",
          "refId": "A"
        }
      ]
    }
  ]
}
