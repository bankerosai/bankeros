# ===== BankerOS Environment Configuration =====
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_USER=bankeros
POSTGRES_PASSWORD=bankeros_secret
POSTGRES_DB=bankeros_core
DATABASE_URL=postgresql://bankeros:bankeros_secret@localhost:5432/bankeros_core

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=86400

# Kafka
KAFKA_BROKERS=localhost:9092

# Service URLs (for inter-service communication)
IAM_SERVICE_URL=http://localhost:3001
GL_SERVICE_URL=http://localhost:3002
ONBOARDING_SERVICE_URL=http://localhost:3003
LENDING_SERVICE_URL=http://localhost:3004
PAYMENTS_SERVICE_URL=http://localhost:3005
COMPLIANCE_SERVICE_URL=http://localhost:3006
TRADE_FINANCE_SERVICE_URL=http://localhost:3007
WEALTH_SERVICE_URL=http://localhost:3008
LIQUIDITY_SERVICE_URL=http://localhost:3009
BATCH_SERVICE_URL=http://localhost:3010

# External APIs (configure for production)
FX_RATES_API_KEY=
SANCTIONS_LIST_API_KEY=
SWIFT_API_KEY=
LIVENESS_DETECTION_API_KEY=

# Encryption
ENCRYPTION_KEY=change_this_32_byte_hex_key_in_prod

# ===== Banker Copilot =====
ANTHROPIC_API_KEY=
COPILOT_MODEL=claude-sonnet-4-5
COPILOT_MAX_TOKENS=4096
COPILOT_MAX_TOOL_ROUNDS=8
COPILOT_PRICE_INPUT=3
COPILOT_PRICE_OUTPUT=15
COPILOT_PRICE_CACHE_READ=0.3
COPILOT_PRICE_CACHE_WRITE=3.75
BANKER_COPILOT_SERVICE_URL=http://localhost:3017
